# WhatsApp
# Comma-separated list of WhatsApp JIDs allowed to use the bot
ALLOWED_JIDS=1234567890@s.whatsapp.net,9876543210@lid
WHATSMEOW_DB_PATH=./data/whatsmeow.db

# Google OAuth2 credentials
GOOGLE_CLIENT_ID=obvi-fake-client-id-12345.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=obvi-fake-client-secret-abcde
GOOGLE_REFRESH_TOKEN=obvi-fake-refresh-token-xyz789  # obtained via: cd go && go build -o ../bin/auth-google ./cmd/auth-google/ && ../bin/auth-google

# Google Docs template IDs (from the URL of each template doc)
TEMPLATE_ID_IG=obvi-fake-template-id-ig-doc-12345
TEMPLATE_ID_IG_FB=obvi-fake-template-id-ig-fb-doc-54321

# Google Drive folder ID (from folder URL) — campaign subfolders are created here
OUTPUT_FOLDER_ID=obvi-fake-output-folder-id-67890

# Behaviour
# Substring in caption body that selects the IG-only template (absence selects IG+FB)
TRIGGER_URL=instagram.com/p/
OUTPUT_DOC_PERMISSION=commenter   # reader, commenter, or writer
PAIRING_TIMEOUT_MS=120000
