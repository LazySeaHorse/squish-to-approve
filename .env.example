# WhatsApp
# Your own WhatsApp JID, e.g. 447911123456@s.whatsapp.net
ALLOWED_JIDS=YOUR_NUMBER@s.whatsapp.net
BAILEYS_DB_PATH=./data/baileys.db

# Google OAuth2
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token  # obtained via: npm run auth:google

# Google Docs template IDs (from the URL of each template doc)
TEMPLATE_ID_IG=1aBcDeFgHiJkLmNoPqRsTuVwXyZ
TEMPLATE_ID_IG_FB=2aBcDeFgHiJkLmNoPqRsTuVwXyZ

# Google Drive folder IDs (from folder URL)
OUTPUT_FOLDER_ID=folder-id-for-approval-docs
TEMP_IMAGE_FOLDER_ID=folder-id-for-temp-uploads

# Behaviour
# Substring that triggers the IG+FB template (must appear in caption body)
TRIGGER_URL=instagram.com/p/
OUTPUT_DOC_PERMISSION=reader   # reader or writer
PAIRING_TIMEOUT_MS=120000
